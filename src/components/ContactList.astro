---
import { card } from '../config';
import SocialIcon from './SocialIcon.astro';

const phoneTel = card.phone?.replace(/[^\d+]/g, '');
const websiteDisplay = card.website.replace(/^https?:\/\//, '').replace(/\/$/, '');

const addressDisplay = card.address
  ? [
      card.address.street,
      [card.address.city, card.address.region].filter(Boolean).join(', '),
      [card.address.postalCode, card.address.country].filter(Boolean).join(' · '),
    ]
      .filter(Boolean)
      .join(' · ')
  : '';

const mapsUrl = card.address
  ? `https://maps.apple.com/?q=${encodeURIComponent(
      [card.address.street, card.address.city, card.address.region, card.address.country]
        .filter(Boolean)
        .join(', ')
    )}`
  : '';
---

<section class="contacts" aria-label="Coordonnées">
  {card.phone && (
    <a href={`tel:${phoneTel}`} class="row">
      <span class="row-label">{card.labels.phone}</span>
      <span class="row-value">{card.phone}</span>
    </a>
  )}

  <a href={`mailto:${card.email}`} class="row">
    <span class="row-label">{card.labels.email}</span>
    <span class="row-value">{card.email}</span>
  </a>

  <a href={card.website} class="row" target="_blank" rel="noopener">
    <span class="row-label">{card.labels.website}</span>
    <span class="row-value">{websiteDisplay}</span>
  </a>

  {addressDisplay && (
    <a href={mapsUrl} class="row" target="_blank" rel="noopener">
      <span class="row-label">{card.labels.address}</span>
      <span class="row-value">{addressDisplay}</span>
    </a>
  )}

  {card.socials.map((s) => (
    <a href={s.url} class="row" target="_blank" rel="noopener">
      <span class="row-label">
        <span class="row-icon"><SocialIcon icon={s.icon} /></span>
        {s.label}
      </span>
      <span class="row-value row-value--muted">↗</span>
    </a>
  ))}
</section>

<style>
  .contacts {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 16px 4px;
    border-bottom: 1px solid var(--border);
    transition: background 180ms ease;
    -webkit-tap-highlight-color: transparent;
  }

  .row:last-child {
    border-bottom: none;
  }

  .row:hover {
    background: var(--bg-elev);
  }

  .row-label {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    flex-shrink: 0;
  }

  .row-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 14px;
    height: 14px;
    color: var(--text-secondary);
  }

  .row-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .row-value {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--text-primary);
    text-align: right;
    word-break: break-word;
    min-width: 0;
  }

  .row-value--muted {
    color: var(--text-tertiary);
    font-size: 1.1rem;
    line-height: 1;
  }
</style>
