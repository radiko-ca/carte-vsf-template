---
import { card } from '../config';
const downloadName = `${card.firstName}-${card.lastName}.vcf`;
---

<div
  id="ios-modal"
  class="vcm"
  hidden
  role="dialog"
  aria-modal="true"
  aria-labelledby="vcm-title"
>
  <div class="vcm-backdrop" data-close></div>

  <div class="vcm-panel" role="document">
    <button type="button" class="vcm-close" aria-label="Fermer" data-close>
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <h2 id="vcm-title" class="vcm-title">Avant d'ouvrir la fiche</h2>
    <p class="vcm-sub">
      Sur iPhone, voici comment <strong>réellement enregistrer</strong> cette carte dans tes contacts.
    </p>

    <div class="vcm-illu" aria-hidden="true">
      <svg viewBox="0 0 280 240" xmlns="http://www.w3.org/2000/svg">
        <rect x="8" y="8" width="264" height="120" rx="14" fill="#1c1c1e" stroke="rgba(255,255,255,0.08)" stroke-width="1"/>
        <circle cx="40" cy="40" r="14" fill="#3a3a3c"/>
        <rect x="62" y="32" width="100" height="6" rx="3" fill="#48484a"/>
        <rect x="62" y="44" width="70" height="5" rx="2.5" fill="#3a3a3c"/>
        <line x1="20" y1="68" x2="260" y2="68" stroke="rgba(255,255,255,0.06)"/>
        <rect x="20" y="80" width="60" height="5" rx="2.5" fill="#3a3a3c"/>
        <rect x="20" y="92" width="120" height="6" rx="3" fill="#48484a"/>
        <line x1="20" y1="110" x2="260" y2="110" stroke="rgba(255,255,255,0.06)"/>

        <rect x="8" y="140" width="264" height="44" rx="14" fill="#1c1c1e" stroke="#ffffff" stroke-width="2"/>
        <text x="140" y="167" font-family="-apple-system, BlinkMacSystemFont, sans-serif" font-size="14" font-weight="600" fill="#ffffff" text-anchor="middle">Create New Contact</text>

        <rect x="8" y="190" width="264" height="38" rx="14" fill="#1c1c1e" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>
        <text x="140" y="214" font-family="-apple-system, BlinkMacSystemFont, sans-serif" font-size="13" fill="rgba(255,255,255,0.45)" text-anchor="middle">Add to Existing Contact</text>

        <path d="M 245 130 Q 270 140 258 158" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round"/>
        <path d="M 258 158 l -6 -3 m 6 3 l -1 -7" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>

    <ol class="vcm-steps">
      <li><span>1</span>La fiche s'ouvre par-dessus la page</li>
      <li><span>2</span>Fais défiler jusqu'en <strong>bas</strong> de la fiche</li>
      <li><span>3</span>Appuie sur <strong>Create New Contact</strong></li>
    </ol>

    <p class="vcm-warn">
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
        <line x1="12" y1="9" x2="12" y2="13"/>
        <line x1="12" y1="17" x2="12.01" y2="17"/>
      </svg>
      Le crochet bleu en haut <strong>ferme la fiche sans enregistrer</strong>.
    </p>

    <div class="vcm-actions">
      <a
        href="/contact.vcf"
        download={downloadName}
        id="vcm-go"
        class="vcm-btn vcm-btn--primary"
      >
        Ouvrir la fiche
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
      <button type="button" class="vcm-cancel" data-close>Annuler</button>
    </div>
  </div>
</div>

<style>
  .vcm {
    position: fixed;
    inset: 0;
    z-index: 999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    animation: vcm-fade 200ms ease-out;
  }
  .vcm[hidden] {
    display: none;
  }
  .vcm-backdrop {
    position: absolute;
    inset: 0;
    background: var(--modal-backdrop);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .vcm-panel {
    position: relative;
    width: 100%;
    max-width: 420px;
    max-height: calc(100svh - 40px);
    overflow-y: auto;
    background: var(--modal-panel);
    border: 1px solid var(--modal-panel-border);
    border-radius: var(--radius-xl);
    padding: 32px 28px 24px;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.18);
    animation: vcm-pop 280ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .vcm-close {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-elev);
    border-radius: 50%;
    color: var(--text-secondary);
    transition:
      background 180ms ease,
      color 180ms ease;
  }
  .vcm-close:hover {
    background: var(--border);
    color: var(--text-primary);
  }
  .vcm-title {
    font-family: var(--font-sans);
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin: 0 0 6px;
    padding-right: 36px;
  }
  .vcm-sub {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0 0 20px;
  }
  .vcm-sub strong {
    color: var(--text-primary);
    font-weight: 600;
  }
  .vcm-illu {
    width: 100%;
    background: var(--modal-illu-bg);
    border: 1px solid var(--modal-illu-border);
    border-radius: var(--radius-md);
    padding: 14px;
    margin-bottom: 20px;
  }
  .vcm-illu svg {
    width: 100%;
    height: auto;
    display: block;
  }
  .vcm-steps {
    list-style: none;
    padding: 0;
    margin: 0 0 18px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .vcm-steps li {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--text-primary);
    line-height: 1.45;
  }
  .vcm-steps li span {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--accent);
    color: var(--accent-on);
    border-radius: 50%;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
  }
  .vcm-steps strong {
    font-weight: 600;
  }
  .vcm-warn {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    padding: 10px 12px;
    margin: 0 0 22px;
    border-radius: var(--radius-sm);
    background: var(--warn-bg);
    border: 1px solid var(--warn-border);
    color: var(--text-secondary);
    font-family: var(--font-sans);
    font-size: 0.8rem;
    line-height: 1.45;
  }
  .vcm-warn svg {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--warn-icon);
  }
  .vcm-warn strong {
    color: var(--text-primary);
    font-weight: 600;
  }
  .vcm-actions {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .vcm-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    height: 48px;
    border-radius: var(--radius-pill);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
    transition:
      background 180ms ease,
      transform 180ms ease;
  }
  .vcm-btn--primary {
    background: var(--accent);
    color: var(--accent-on);
  }
  .vcm-btn--primary:hover {
    background: var(--accent-hover);
  }
  .vcm-btn--primary:active {
    transform: scale(0.98);
  }
  .vcm-cancel {
    color: var(--text-secondary);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    padding: 10px;
    transition: color 180ms ease;
  }
  .vcm-cancel:hover {
    color: var(--text-primary);
  }
  @keyframes vcm-fade {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes vcm-pop {
    from { opacity: 0; transform: translateY(10px) scale(0.98); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  @media (max-width: 380px) {
    .vcm-panel {
      padding: 28px 20px 20px;
    }
    .vcm-title {
      font-size: 1.25rem;
    }
  }
</style>
